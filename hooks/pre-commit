#!/bin/sh
# pre-commit hook — dart_collector / fs_dart 변경 시 무결성 자동 검사
# 2026-05-12 SG&A 매핑 사고 재발 방지
#
# Git for Windows 환경에서 자동으로 sh 호출 (mingw64 환경).
# Linux/Mac도 동일.

REPO="$(git rev-parse --show-toplevel)"

# Python 경로 (Windows + miniconda 환경 자동 탐지)
if [ -f "/c/Users/user/miniconda3/envs/volumequant/python.exe" ]; then
    PYTHON="/c/Users/user/miniconda3/envs/volumequant/python.exe"
elif command -v python >/dev/null 2>&1; then
    PYTHON="python"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON="python3"
else
    echo "[pre-commit] ⚠️ Python not found in PATH — skip"
    exit 0
fi

# UTF-8 출력 강제 (Windows cp949 회피)
export PYTHONIOENCODING=utf-8

# 1. dart_collector.py 변경 → unit test
if git diff --cached --name-only | grep -q "dart_collector.py"; then
    echo "[pre-commit] dart_collector.py 변경 검출 -> 매핑 무결성 검사"
    if [ -f "$REPO/test_account_map.py" ]; then
        "$PYTHON" "$REPO/test_account_map.py"
        if [ $? -ne 0 ]; then
            echo "[pre-commit] FAIL: 매핑 무결성 검사 실패 - commit 차단"
            echo "  --no-verify 사용 금지 (사고 재발 위험)"
            exit 1
        fi
    fi
fi

# 2. fs_dart 캐시 변경 → FN 5배+ 차이 검사 (표본 10)
CHANGED_FS=$(git diff --cached --name-only | grep "data_cache/fs_dart_" | head -10)
if [ -n "$CHANGED_FS" ]; then
    NUM_CHANGED=$(echo "$CHANGED_FS" | wc -l)
    echo "[pre-commit] fs_dart 캐시 변경 검출 -> 무결성 검사 (표본 $NUM_CHANGED)"

    "$PYTHON" - <<PYEOF
import sys, os
import pandas as pd
sys.stdout.reconfigure(encoding='utf-8')

suspicious = []
files = """$CHANGED_FS""".strip().split('\n')
for fp_rel in files:
    fp = os.path.join("$REPO", fp_rel)
    if not os.path.exists(fp):
        continue
    try:
        b = pd.read_parquet(fp)
        rev = b[(b['공시구분']=='q') & (b['계정']=='매출액') & (b['기준일']==pd.Timestamp('2024-03-31'))]
        if rev.empty:
            continue
        v = float(rev['값'].iloc[0])
        tk = os.path.basename(fp).replace('fs_dart_', '').replace('.parquet', '')
        fn_fp = os.path.join("$REPO", 'data_cache', f'fs_fnguide_{tk}.parquet')
        if not os.path.exists(fn_fp):
            continue
        f = pd.read_parquet(fn_fp)
        f_rev = f[(f['공시구분']=='q') & (f['계정']=='매출액') & (f['기준일']==pd.Timestamp('2024-03-31'))]
        if f_rev.empty:
            continue
        fv = float(f_rev['값'].iloc[0])
        if v != 0 and fv != 0 and (fv/v > 5 or v/fv > 5):
            suspicious.append((tk, v, fv))
    except Exception:
        pass

if suspicious:
    print('  매출 5배+ 차이 의심 종목:')
    for tk, dv, fv in suspicious:
        print(f'    {tk}: DART {dv:.1f}억 vs FN {fv:.1f}억')
    print('  -> SG&A 매핑 흔적 가능성. refetch_serial.py로 재수집 후 다시 commit')
    sys.exit(2)
else:
    print('  fs_dart 매출 정상')
PYEOF

    if [ $? -eq 2 ]; then
        echo "[pre-commit] FAIL: fs_dart 무결성 의심 - commit 차단"
        exit 1
    fi
fi

echo "[pre-commit] 모든 검사 통과"
exit 0
